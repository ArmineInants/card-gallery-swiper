{
  "name": "card-gallery-swiper",
  "version": "1.0.0",
  "description": "A React card gallery swiper with constrained layout and modal image viewer.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "clean": "rimraf dist",
    "dev": "vite",
    "build:demo": "vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=16.8 || >=17 || >=18",
    "react-dom": ">=16.8 || >=17 || >=18",
    "styled-components": ">=5"
  },
  "dependencies": {
    "body-scroll-lock": "^4.0.0-beta.0",
    "prop-types": "^15.8.1",
    "react-lazyload": "^3.2.1",
    "styled-components": ">=5"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-lazyload": "^3.1.0",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.0",
    "sass": "^1.71.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vite": "^7.3.1"
  },
  "keywords": [
    "react",
    "swiper",
    "carousel",
    "gallery",
    "cards",
    "styled-components"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArmineInants/card-gallery-swiper.git"
  },
  "bugs": {
    "url": "https://github.com/ArmineInants/card-gallery-swiper/issues"
  },
  "homepage": "https://github.com/ArmineInants/card-gallery-swiper#readme",
  "license": "MIT"
}
