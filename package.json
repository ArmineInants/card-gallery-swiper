{
  "name": "card-gallery-swiper",
  "version": "1.1.7",
  "description": "React TypeScript horizontal card gallery and image carousel: container-aligned layout, edge-to-edge scroll, optional modal lightbox. styled-components. React 16.8+.",
  "author": "Armine Inants",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "clean": "rimraf dist",
    "dev": "vite",
    "build:demo": "vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=16.8 || >=17 || >=18",
    "react-dom": ">=16.8 || >=17 || >=18",
    "styled-components": ">=5"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vite": "^7.3.1"
  },
  "keywords": [
    "react",
    "typescript",
    "react-component",
    "ui-component",
    "styled-components",
    "react-gallery",
    "react-image-gallery",
    "react-carousel",
    "react-swiper",
    "react-slider",
    "image-gallery",
    "image-carousel",
    "image-slider",
    "image-lightbox",
    "lightbox",
    "photo-gallery",
    "product-gallery",
    "card-gallery",
    "gallery-swiper",
    "gallery-carousel",
    "modal-gallery",
    "react-modal-gallery",
    "horizontal-scroll",
    "react-horizontal-scroll",
    "responsive-gallery",
    "touch"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArmineInants/card-gallery-swiper.git"
  },
  "bugs": {
    "url": "https://github.com/ArmineInants/card-gallery-swiper/issues"
  },
  "homepage": "https://card-gallery-swiper.vercel.app/",
  "license": "MIT"
}
